//@version=5
indicator("Quadratic Regression Validator", overlay=true, max_lines_count=500)

length = input.int(30, "Window", minval=5)
mode = input.string("avg", "Validation mode", options=["avg", "envelope", "inner"])
tolerance = input.float(0.12, "Tolerance", minval=0.0, step=0.01)
maxFailed = input.int(4, "Max failed predictions", minval=0)
smoothingAlpha = input.float(0.35, "Smoothing alpha", minval=0.0, maxval=1.0, step=0.01)
predictionHorizon = input.int(1, "Prediction horizon", minval=1, maxval=20)

f_solve3x3(a00, a01, a02, b0, a10, a11, a12, b1, a20, a21, a22, b2) =>
    det = a00 * (a11 * a22 - a12 * a21) - a01 * (a10 * a22 - a12 * a20) + a02 * (a10 * a21 - a11 * a20)
    if math.abs(det) < 1e-10
        [na, na, na]
    else
        detA = b0 * (a11 * a22 - a12 * a21) - a01 * (b1 * a22 - a12 * b2) + a02 * (b1 * a21 - a11 * b2)
        detB = a00 * (b1 * a22 - a12 * b2) - b0 * (a10 * a22 - a12 * a20) + a02 * (a10 * b2 - b1 * a20)
        detC = a00 * (a11 * b2 - b1 * a21) - a01 * (a10 * b2 - b1 * a20) + b0 * (a10 * a21 - a11 * a20)
        [detA / det, detB / det, detC / det]

f_fit(len) =>
    // Closed-form sums for x in [0, len-1] => O(1) for x-moments.
    l = float(len)
    lm1 = l - 1.0
    sx = l * lm1 / 2.0
    sx2 = l * lm1 * (2.0 * l - 1.0) / 6.0
    sx3 = math.pow(sx, 2)
    sx4 = l * lm1 * (2.0 * l - 1.0) * (3.0 * l * l - 3.0 * l - 1.0) / 30.0

    float sy = 0.0
    float sxy = 0.0
    float sx2y = 0.0

    for i = 0 to len - 1
        x = i
        y = close[i]
        x2 = x * x
        sy += y
        sxy += x * y
        sx2y += x2 * y

    [a, b, c] = f_solve3x3(sx4, sx3, sx2, sx2y, sx3, sx2, sx, sxy, sx2, sx, l, sy)
    [a, b, c]

f_inside(a, y, yCurve, tol) =>
    a >= 0 ? y >= (yCurve - tol) : y <= (yCurve + tol)

var float aSmooth = na
var float bSmooth = na
var float cSmooth = na

if bar_index >= length
    [aFit, bFit, cFit] = f_fit(length)
    if na(aFit)
        aSmooth := na
        bSmooth := na
        cSmooth := na
    else
        if na(aSmooth)
            aSmooth := aFit
            bSmooth := bFit
            cSmooth := cFit
        else
            oneMinus = 1.0 - smoothingAlpha
            aSmooth := smoothingAlpha * aFit + oneMinus * aSmooth
            bSmooth := smoothingAlpha * bFit + oneMinus * bSmooth
            cSmooth := smoothingAlpha * cFit + oneMinus * cSmooth

failed = 0
if not na(aSmooth)
    for i = 0 to length - 1
        x = i
        y = close[i]
        yCurve = aSmooth * x * x + bSmooth * x + cSmooth
        isInside = f_inside(aSmooth, y, yCurve, tolerance)
        isAvgFail = math.abs(yCurve - y) > tolerance
        isFail = mode == "avg" ? isAvgFail : mode == "envelope" ? not isInside : isInside
        failed += isFail ? 1 : 0
        if failed > maxFailed
            break

isValid = failed <= maxFailed
xNow = 0
yNow = na(aSmooth) ? na : aSmooth * xNow * xNow + bSmooth * xNow + cSmooth
xFuture = predictionHorizon
yPred = na(aSmooth) ? na : aSmooth * xFuture * xFuture + bSmooth * xFuture + cSmooth

plot(yNow, "Quadratic y_calc", color=isValid ? color.lime : color.red, linewidth=2)
plot(yPred, "Quadratic y_pred", color=color.new(color.orange, 0), linewidth=2, style=plot.style_linebr)

plotchar(isValid, "valid", "✓", location.top, color=color.lime, size=size.tiny)
plotchar(not isValid and not na(aSmooth), "invalid", "✕", location.top, color=color.red, size=size.tiny)

bgcolor(mode == "envelope" ? color.new(color.blue, 92) : mode == "inner" ? color.new(color.purple, 92) : color.new(color.green, 94))
