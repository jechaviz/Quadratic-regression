//@version=5
indicator("Quadratic Regression Validator", overlay=true, max_lines_count=500)

length = input.int(30, "Window", minval=5)
mode = input.string("avg", "Validation mode", options=["avg", "envelope", "inner"])
tolerance = input.float(0.12, "Tolerance", minval=0.0, step=0.01)
maxFailed = input.int(4, "Max failed predictions", minval=0)
predictionHorizon = input.int(1, "Prediction horizon", minval=1, maxval=20)
markovLookback = input.int(30, "Markov lookback", minval=4, maxval=200)
hurstMinPoints = input.int(20, "Hurst min points", minval=10, maxval=300)
predictiveStrength = input.float(0.65, "Predictive strength", minval=0.0, maxval=2.0, step=0.05)

f_solve3x3(a00, a01, a02, b0, a10, a11, a12, b1, a20, a21, a22, b2) =>
    det = a00 * (a11 * a22 - a12 * a21) - a01 * (a10 * a22 - a12 * a20) + a02 * (a10 * a21 - a11 * a20)
    if math.abs(det) < 1e-10
        [na, na, na]
    else
        detA = b0 * (a11 * a22 - a12 * a21) - a01 * (b1 * a22 - a12 * b2) + a02 * (b1 * a21 - a11 * b2)
        detB = a00 * (b1 * a22 - a12 * b2) - b0 * (a10 * a22 - a12 * a20) + a02 * (a10 * b2 - b1 * a20)
        detC = a00 * (a11 * b2 - b1 * a21) - a01 * (a10 * b2 - b1 * a20) + b0 * (a10 * a21 - a11 * a20)
        [detA / det, detB / det, detC / det]

f_fit(len) =>
    l = float(len)
    lm1 = l - 1.0
    sx = l * lm1 / 2.0
    sx2 = l * lm1 * (2.0 * l - 1.0) / 6.0
    sx3 = math.pow(sx, 2)
    sx4 = l * lm1 * (2.0 * l - 1.0) * (3.0 * l * l - 3.0 * l - 1.0) / 30.0

    float sy = 0.0
    float sxy = 0.0
    float sx2y = 0.0

    for i = 0 to len - 1
        x = i
        y = close[i]
        x2 = x * x
        sy += y
        sxy += x * y
        sx2y += x2 * y

    [a, b, c] = f_solve3x3(sx4, sx3, sx2, sx2y, sx3, sx2, sx, sxy, sx2, sx, l, sy)
    [a, b, c]

f_inside(a, y, yCurve, tol) =>
    a >= 0 ? y >= (yCurve - tol) : y <= (yCurve + tol)

f_markov_bias(lb) =>
    upUp = 1e-9
    upDown = 1e-9
    downUp = 1e-9
    downDown = 1e-9
    lim = math.min(lb, bar_index - 2)
    for i = 0 to lim - 1
        prev = close[i + 1] - close[i + 2]
        curr = close[i] - close[i + 1]
        prevState = prev >= 0 ? 1 : -1
        currState = curr >= 0 ? 1 : -1
        if prevState == 1 and currState == 1
            upUp += 1
        else if prevState == 1 and currState == -1
            upDown += 1
        else if prevState == -1 and currState == 1
            downUp += 1
        else
            downDown += 1

    nowState = close - close[1] >= 0 ? 1 : -1
    pUp = nowState == 1 ? upUp / (upUp + upDown) : downUp / (downUp + downDown)
    2.0 * pUp - 1.0

f_hurst(n) =>
    if n < 10
        0.5
    else
        float mean = 0.0
        for i = 0 to n - 1
            mean += close[i]
        mean /= n

        float variance = 0.0
        float cumulative = 0.0
        float maxCum = -1e10
        float minCum = 1e10

        for i = n - 1 to 0
            v = close[i] - mean
            variance += v * v
            cumulative += v
            maxCum := math.max(maxCum, cumulative)
            minCum := math.min(minCum, cumulative)

        s = math.sqrt(variance / n)
        r = maxCum - minCum
        h = s <= 1e-10 or r <= 1e-10 ? 0.5 : math.log(r / s) / math.log(n)
        math.max(0.0, math.min(1.0, h))

[aFit, bFit, cFit] = bar_index >= length ? f_fit(length) : [na, na, na]
aSmooth = aFit
bSmooth = bFit
cSmooth = cFit

failed = 0
if not na(aSmooth)
    for i = 0 to length - 1
        x = i
        y = close[i]
        yCurve = aSmooth * x * x + bSmooth * x + cSmooth
        isInside = f_inside(aSmooth, y, yCurve, tolerance)
        isAvgFail = math.abs(yCurve - y) > tolerance
        isFail = mode == "avg" ? isAvgFail : mode == "envelope" ? not isInside : isInside
        failed += isFail ? 1 : 0
        if failed > maxFailed
            break

isValid = failed <= maxFailed
xNow = 0.0
yNow = na(aSmooth) ? na : aSmooth * xNow * xNow + bSmooth * xNow + cSmooth

markovBias = bar_index > 5 ? f_markov_bias(markovLookback) : 0.0
hurstN = math.min(hurstMinPoints, bar_index + 1)
hurst = f_hurst(hurstN)
memoryRegime = (hurst - 0.5) * 2.0
slopeState = na(bSmooth) ? 0.0 : (bSmooth >= 0 ? 1.0 : -1.0)
directionalBias = 0.5 * markovBias + 0.5 * slopeState
boostRaw = 1.0 + predictiveStrength * directionalBias * memoryRegime
boost = math.max(0.25, math.min(2.5, boostRaw))

xFuture = predictionHorizon * boost
yPred = na(aSmooth) ? na : aSmooth * xFuture * xFuture + bSmooth * xFuture + cSmooth

isUp = not na(yNow) and not na(yPred) ? yPred >= yNow : false
softBlue = color.rgb(120, 175, 255)
softPink = color.rgb(255, 150, 210)
trendColor = isUp ? softBlue : softPink

plot(yNow, "Quadratic y_calc", color=color.new(trendColor, isValid ? 0 : 35), linewidth=2)
plot(yPred, "Quadratic y_pred", color=color.new(trendColor, 10), linewidth=2, style=plot.style_linebr)

plotchar(isValid, "valid", "✓", location.top, color=color.new(softBlue, 0), size=size.tiny)
plotchar(not isValid and not na(aSmooth), "invalid", "✕", location.top, color=color.new(softPink, 0), size=size.tiny)

bgcolor(color.new(trendColor, mode == "avg" ? 92 : 90))
