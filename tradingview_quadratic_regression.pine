//@version=5
indicator("Quadratic Regression Validator", overlay=true, max_lines_count=500)

length = input.int(30, "Window", minval=5)
mode = input.string("avg", "Validation mode", options=["avg", "envelope", "inner"])
tolerance = input.float(0.12, "Tolerance", minval=0.0, step=0.01)
maxFailed = input.int(4, "Max failed predictions", minval=0)

f_solve3x3(a00, a01, a02, b0, a10, a11, a12, b1, a20, a21, a22, b2) =>
    det = a00 * (a11 * a22 - a12 * a21) - a01 * (a10 * a22 - a12 * a20) + a02 * (a10 * a21 - a11 * a20)
    if math.abs(det) < 1e-10
        [na, na, na]
    else
        detA = b0 * (a11 * a22 - a12 * a21) - a01 * (b1 * a22 - a12 * b2) + a02 * (b1 * a21 - a11 * b2)
        detB = a00 * (b1 * a22 - a12 * b2) - b0 * (a10 * a22 - a12 * a20) + a02 * (a10 * b2 - b1 * a20)
        detC = a00 * (a11 * b2 - b1 * a21) - a01 * (a10 * b2 - b1 * a20) + b0 * (a10 * a21 - a11 * a20)
        [detA / det, detB / det, detC / det]

f_fit(len) =>
    float sx = 0.0
    float sx2 = 0.0
    float sx3 = 0.0
    float sx4 = 0.0
    float sy = 0.0
    float sxy = 0.0
    float sx2y = 0.0

    for i = 0 to len - 1
        x = i
        y = close[i]
        x2 = x * x
        sx += x
        sx2 += x2
        sx3 += x2 * x
        sx4 += x2 * x2
        sy += y
        sxy += x * y
        sx2y += x2 * y

    [a, b, c] = f_solve3x3(sx4, sx3, sx2, sx2y, sx3, sx2, sx, sxy, sx2, sx, len, sy)
    [a, b, c]

f_inside(a, y, yCurve, tol) =>
    a >= 0 ? y >= (yCurve - tol) : y <= (yCurve + tol)

var line curve = na
[a, b, c] = bar_index >= length ? f_fit(length) : [na, na, na]

failed = 0
if not na(a)
    for i = 0 to length - 1
        x = i
        y = close[i]
        yCurve = a * x * x + b * x + c
        isInside = f_inside(a, y, yCurve, tolerance)
        isAvgFail = math.abs(yCurve - y) > tolerance
        isFail = mode == "avg" ? isAvgFail : mode == "envelope" ? not isInside : isInside
        failed += isFail ? 1 : 0

isValid = failed <= maxFailed
xNow = 0
yNow = na(a) ? na : a * xNow * xNow + b * xNow + c
plot(yNow, "Quadratic y_calc", color=isValid ? color.lime : color.red, linewidth=2)

plotchar(isValid, "valid", "✓", location.top, color=color.lime, size=size.tiny)
plotchar(not isValid and not na(a), "invalid", "✕", location.top, color=color.red, size=size.tiny)

bgcolor(mode == "envelope" ? color.new(color.blue, 92) : mode == "inner" ? color.new(color.purple, 92) : color.new(color.green, 94))
