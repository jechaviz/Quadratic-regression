//@version=5
indicator("Quadratic Regression Validator", overlay=true, max_lines_count=500)

length = input.int(30, "Window", minval=5)
mode = input.string("avg", "Validation mode", options=["avg", "envelope", "inner"])
tolerance = input.float(0.12, "Tolerance", minval=0.0, step=0.01)
maxFailed = input.int(4, "Max failed predictions", minval=0)
predictionHorizon = input.int(1, "Prediction horizon", minval=1, maxval=20)
markovLookback = input.int(30, "Markov lookback", minval=4, maxval=300)
hurstMinPoints = input.int(20, "Persistence min points", minval=4, maxval=300)
predictiveStrength = input.float(0.65, "Predictive strength", minval=0.0, maxval=2.0, step=0.05)

f_solve3x3(a00, a01, a02, b0, a10, a11, a12, b1, a20, a21, a22, b2) =>
    det = a00 * (a11 * a22 - a12 * a21) - a01 * (a10 * a22 - a12 * a20) + a02 * (a10 * a21 - a11 * a20)
    if math.abs(det) < 1e-10
        [0.0, 0.0, 0.0, false]
    else
        detA = b0 * (a11 * a22 - a12 * a21) - a01 * (b1 * a22 - a12 * b2) + a02 * (b1 * a21 - a11 * b2)
        detB = a00 * (b1 * a22 - a12 * b2) - b0 * (a10 * a22 - a12 * a20) + a02 * (a10 * b2 - b1 * a20)
        detC = a00 * (a11 * b2 - b1 * a21) - a01 * (a10 * b2 - b1 * a20) + b0 * (a10 * a21 - a11 * a20)
        [detA / det, detB / det, detC / det, true]

f_fit(len) =>
    l = float(len)
    lm1 = l - 1.0
    sx = l * lm1 / 2.0
    sx2 = l * lm1 * (2.0 * l - 1.0) / 6.0
    sx3 = math.pow(sx, 2)
    sx4 = l * lm1 * (2.0 * l - 1.0) * (3.0 * l * l - 3.0 * l - 1.0) / 30.0

    float sy = 0.0
    float sxy = 0.0
    float sx2y = 0.0

    for i = 0 to len - 1
        x = i
        y = close[i]
        x2 = x * x
        sy += y
        sxy += x * y
        sx2y += x2 * y

    [a, b, c, ok] = f_solve3x3(sx4, sx3, sx2, sx2y, sx3, sx2, sx, sxy, sx2, sx, l, sy)
    [a, b, c, ok]

f_inside(a, y, yCurve, tol) =>
    a >= 0 ? y >= (yCurve - tol) : y <= (yCurve + tol)

alpha = 2.0 / (markovLookback + 1.0)
decay = 1.0 - alpha

var float uu = 1e-6
var float ud = 1e-6
var float du = 1e-6
var float dd = 1e-6
var float retEma = 0.0
var float retVarEma = 0.0
var float accelEma = 0.0
var float absRetEma = 0.0
var float prevRet = 0.0
var int prevState = 0
var int sampleCount = 0

if bar_index > 0
    ret = close - close[1]
    state = ret >= 0 ? 1 : -1

    if prevState != 0
        uu := uu * decay
        ud := ud * decay
        du := du * decay
        dd := dd * decay
        if prevState == 1 and state == 1
            uu += 1.0
        else if prevState == 1 and state == -1
            ud += 1.0
        else if prevState == -1 and state == 1
            du += 1.0
        else
            dd += 1.0

    d = ret - retEma
    retEma += alpha * d
    retVarEma := (1.0 - alpha) * retVarEma + alpha * (d * d)
    accelEma := (1.0 - alpha) * accelEma + alpha * (ret - prevRet)
    absRetEma := (1.0 - alpha) * absRetEma + alpha * math.abs(ret)

    prevRet := ret
    prevState := state
    sampleCount += 1

float aModel = na
float bModel = na
float cModel = na
if bar_index >= length
    [aFit, bFit, cFit, okFit] = f_fit(length)
    if okFit
        aModel := aFit
        bModel := bFit
        cModel := cFit

failed = 0
if not na(aModel)
    for i = 0 to length - 1
        x = i
        y = close[i]
        yCurve = aModel * x * x + bModel * x + cModel
        isInside = f_inside(aModel, y, yCurve, tolerance)
        isAvgFail = math.abs(yCurve - y) > tolerance
        isFail = mode == "avg" ? isAvgFail : mode == "envelope" ? not isInside : isInside
        failed += isFail ? 1 : 0
        if failed > maxFailed
            break

isValid = failed <= maxFailed
xNow = 0.0
yNow = na(aModel) ? na : aModel * xNow * xNow + bModel * xNow + cModel

markovBias = prevState == 1 ? (2.0 * (uu / (uu + ud)) - 1.0) : prevState == -1 ? (2.0 * (du / (du + dd)) - 1.0) : 0.0
pStayUp = uu / (uu + ud)
pStayDown = dd / (dd + du)
directionalPersistence = 0.5 * (pStayUp + pStayDown)
volatility = math.sqrt(math.max(retVarEma, 1e-12))
trendiness = math.abs(retEma) / (math.abs(retEma) + volatility)
persistence = sampleCount < hurstMinPoints ? 0.5 : math.max(0.0, math.min(1.0, 0.5 + (directionalPersistence - 0.5) * (0.4 + 0.6 * trendiness)))

memoryRegime = (persistence - 0.5) * 2.0
slopeState = na(bModel) ? 0.0 : (bModel >= 0 ? 1.0 : -1.0)
accelState = accelEma >= 0 ? 1.0 : -1.0
directionalBias = 0.45 * markovBias + 0.35 * slopeState + 0.20 * accelState
volPenalty = volatility / (volatility + absRetEma + 1e-9)
confidence = math.max(0.1, 1.0 - 0.7 * volPenalty)
curvatureAlignment = na(aModel) ? 0.0 : ((aModel >= 0 and slopeState > 0) or (aModel < 0 and slopeState < 0) ? 1.0 : -1.0)

boostRaw = 1.0 + predictiveStrength * directionalBias * memoryRegime * confidence + 0.10 * curvatureAlignment * confidence
boost = math.max(0.25, math.min(2.8, boostRaw))

xFuture = predictionHorizon * boost
yPred = na(aModel) ? na : aModel * xFuture * xFuture + bModel * xFuture + cModel

isUp = not na(yNow) and not na(yPred) ? yPred >= yNow : false
softBlue = color.rgb(120, 175, 255)
softPink = color.rgb(255, 150, 210)
trendColor = isUp ? softBlue : softPink

plot(yNow, "Quadratic y_calc", color=color.new(trendColor, isValid ? 0 : 35), linewidth=2)
plot(yPred, "Quadratic y_pred", color=color.new(trendColor, 10), linewidth=2, style=plot.style_linebr)
plotchar(isValid, "valid", "✓", location.top, color=color.new(softBlue, 0), size=size.tiny)
plotchar(not isValid and not na(aModel), "invalid", "✕", location.top, color=color.new(softPink, 0), size=size.tiny)
bgcolor(color.new(trendColor, mode == "avg" ? 92 : 90))
